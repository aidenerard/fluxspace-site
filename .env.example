# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Worker (Python fluxspace-core service)
# Use 127.0.0.1 instead of localhost — macOS resolves localhost to IPv6 ::1
# but Docker typically publishes on IPv4 127.0.0.1 only.
WORKER_URL=http://127.0.0.1:8080
WORKER_SECRET=your-worker-secret

# Optional: MapLibre/Mapbox Token (if using premium basemaps)
NEXT_PUBLIC_MAPLIBRE_TOKEN=
