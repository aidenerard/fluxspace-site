# Supabase (use service role for backend operations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional: path to fluxspace-core scripts (if using external scripts)
FLUXSPACE_CORE_PATH=

# Worker auth (shared secret between Next.js and worker)
# The worker validates Authorization: Bearer <SUPABASE_SERVICE_ROLE_KEY>
